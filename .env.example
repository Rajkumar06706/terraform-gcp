# GCP Configuration
export TF_VAR_gcp_project_id="your-gcp-project-id"
export TF_VAR_gcp_region="us-central1"

# GAR Configuration
export TF_VAR_gar_repository_name="github-docker"
export TF_VAR_gar_repository_description="Docker repository for GitHub CI/CD pipeline"
export TF_VAR_gar_repository_format="docker"

# GitHub Configuration
export TF_VAR_github_token="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export TF_VAR_github_org="your-github-org-or-username"
export TF_VAR_github_repo_name="your-repo-name"

# Service Account Configuration
export TF_VAR_service_account_id="github-gar-sa"
export TF_VAR_workload_identity_pool_id="github-pool"
export TF_VAR_workload_identity_provider_id="github-provider"

# GCP Authentication
export GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"
